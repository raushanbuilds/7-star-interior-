# For more info: https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ============================================================================
# BUILD & COMPILED OUTPUT
# ============================================================================
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/

# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules/

# ============================================================================
# IDE & EDITOR CONFIGURATIONS
# ============================================================================
# IntelliJ/WebStorm
.idea/
.project
.classpath

# Cloud9
.c9/

# General editors
*.launch
.settings/
*.sublime-workspace

# VSCode - keep settings and configs
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Cursor specific
.cursor/rules/

# ============================================================================
# LOGS & DEBUG
# ============================================================================
npm-debug.log*
yarn-error.log*
testem.log

# Coverage reports
/coverage

# ============================================================================
# BUILD & MISC FILES
# ============================================================================
/.sass-cache/
/connect.lock
/libpeerconnection.log
/typings/

# ============================================================================
# SYSTEM & OS SPECIFIC
# ============================================================================
.DS_Store
Thumbs.db

# ============================================================================
# ENVIRONMENT & BUILD TOOLS
# ============================================================================
# Replit
.cache/
.local/

# GitHub
.github/instructions/
